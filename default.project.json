{
  "name": "SimpleRPG",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "Assets": {
        "$path": "assets",
        "$ignoreUnknownInstances": true
      },
      "Shared": {
        "$path": "src/Shared"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "Server": {
        "$path": "src/Server"
      }
    },
    "ServerStorage": {
      "$className": "ServerStorage",
      "$ignoreUnknownInstances": true,
      "AssetStorage": {
        "$path": "src/ServerStorage/AssetStorage",
        "$ignoreUnknownInstances": true,
        "WeaponTemplates": {
          "$path": "src/ServerStorage/AssetStorage/WeaponTemplates",
          "$ignoreUnknownInstances": true
        }
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$ignoreUnknownInstances": true,
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "Client": {
          "$path": "src/Client"
        }
      }
    }
  }
}
