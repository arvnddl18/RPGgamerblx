	loadingLabel.ZIndex = 15
	loadingLabel.Visible = false
	loadingLabel.Parent = mapCanvas
	self._terrainLoadingLabel = loadingLabel
	local loadingCorner = Instance.new("UICorner")
	loadingCorner.CornerRadius = UDim.new(0, 6)
