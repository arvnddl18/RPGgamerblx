        <Item class="ModuleScript" referent="32">
          <Properties>
            <string name="Name">Items</string>
            <string name="Source"><![CDATA[-- weaponSkin: style = grip/visual profile (sword|staff|bow|mace|spear), toolHold = class hold anim
