		startingEquipment = {
			weapon = "WarriorSword",
			helmet = "WarriorHelm",
			shoulders = "WarriorShoulders",
			armor = "WarriorPlate",
			upperArms = "WarriorUpperArms",
			gloves = "WarriorGauntlets",
			pants = "WarriorLeggings",
