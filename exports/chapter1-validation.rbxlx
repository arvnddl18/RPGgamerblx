        <Item class="ModuleScript" referent="34">
          <Properties>
            <string name="Name">LevelGrowth</string>
            <string name="Source"><![CDATA[local ExperienceConfig = require(script.Parent.ExperienceConfig)

local LevelGrowth = {
	perLevel = {
		maxHp = 12,
		maxMana = 5,
		physicalAttack = 2,
		magicAttack = 2,
		defense = 1,
	},
}

function LevelGrowth.GetRequiredXp(level)
	return ExperienceConfig.GetRequiredXp(level)
end

function LevelGrowth.GetLevelBonuses(level)
	local bonuses = {
		maxHp = 0,
		maxMana = 0,
		physicalAttack = 0,
		magicAttack = 0,
		defense = 0,
	}
	local levelsGained = math.max(0, level - 1)
	for stat, amount in LevelGrowth.perLevel do
		bonuses[stat] = amount * levelsGained
	end
	return bonuses
end

return LevelGrowth
]]></string>
          </Properties>
        </Item>
