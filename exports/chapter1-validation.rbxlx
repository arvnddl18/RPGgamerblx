	-- Wyvern & Griffin roaming the far corners
	{ type = "Wyvern", count = 1, center = Vector3.new(600, 3, -1400), radius = 60 },
	{ type = "Griffin", count = 1, center = Vector3.new(-600, 3, 1400), radius = 60 },

